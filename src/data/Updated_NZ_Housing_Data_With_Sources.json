{
	"metadata": {
		"projectTitle": "Visualising Housing Affordability and Market Inequality in New Zealand",
		"subtitle": "Interactive visual analysis of housing affordability trends across five New Zealand cities from 2015 to 2025.",
		"country": "New Zealand",
		"timePeriod": "2015-2025",
		"selectedLocations": [
			"Auckland",
			"Hamilton City",
			"Christchurch City",
			"Wellington City",
			"Queenstown-Lakes District"
		],
		"dataAuthenticityNote": "This dataset structure is designed to use publicly available New Zealand housing and affordability data. The dashboard should avoid describing values as AI-generated, inspired, or interpolated unless those methods are clearly documented. If exact yearly values are manually entered, they should be checked against the listed sources before final submission.",
		"lastUpdatedForProject": "2026-04-30"
	},
	"metricDefinitions": {
		"avgPrice": {
			"label": "Average house value",
			"unit": "NZD",
			"description": "Represents average residential house value or comparable home value measure for the selected Territorial Authority.",
			"recommendedSource": "Cotality/CoreLogic Home Value Index or Infometrics regional housing statistics"
		},
		"avgRent": {
			"label": "Median weekly rent",
			"unit": "NZD per week",
			"description": "Represents median weekly rent for residential tenancies, preferably based on bond lodgement data by Territorial Authority.",
			"recommendedSource": "MBIE / Tenancy Services Rental Bond Data"
		},
		"avgIncome": {
			"label": "Average annual income",
			"unit": "NZD per year",
			"description": "Represents annual income used for affordability comparison. Use a consistent Stats NZ or Infometrics income series across all cities and years.",
			"recommendedSource": "Stats NZ income statistics or Infometrics regional income data"
		},
		"population": {
			"label": "Population estimate",
			"unit": "people",
			"description": "Represents population estimate for the selected Territorial Authority or urban area.",
			"recommendedSource": "Stats NZ subnational population estimates"
		},
		"affordabilityRatio": {
			"label": "House value-to-income ratio",
			"unit": "ratio",
			"description": "Calculated as avgPrice divided by avgIncome. A higher value indicates stronger affordability pressure.",
			"formula": "avgPrice / avgIncome",
			"recommendedSource": "Calculated from house value and income data; can be cross-checked with HUD or Infometrics affordability indicators"
		}
	},
	"dataSources": {
		"priceMetric": {
			"metricKey": "avgPrice",
			"sourceName": "Cotality/CoreLogic Home Value Index or Infometrics regional housing statistics",
			"sourceType": "property value index / regional housing statistics",
			"reasonForUse": "More suitable than simple average sale price because Home Value Index methods reduce compositional bias and cover major cities and Territorial Authorities.",
			"geographicLevel": "Major cities / Territorial Authorities",
			"url": "https://www.cotality.com/nz/our-data/indices"
		},
		"rentMetric": {
			"metricKey": "avgRent",
			"sourceName": "MBIE / Tenancy Services Rental Bond Data",
			"sourceType": "government tenancy bond lodgement data",
			"reasonForUse": "Official rental bond records provide a more reliable basis for rent trends than advertised asking rents.",
			"geographicLevel": "Territorial Authority",
			"url": "https://www.tenancy.govt.nz/about-tenancy-services/data-and-statistics/rental-bond-data/"
		},
		"incomeMetric": {
			"metricKey": "avgIncome",
			"sourceName": "Stats NZ income statistics or Infometrics regional income data",
			"sourceType": "official / regional socio-economic statistics",
			"reasonForUse": "Income data is needed to compare housing cost growth with household earning capacity.",
			"geographicLevel": "Regional / Territorial Authority where available",
			"url": "https://www.stats.govt.nz/"
		},
		"populationMetric": {
			"metricKey": "population",
			"sourceName": "Stats NZ subnational population estimates",
			"sourceType": "official population statistics",
			"reasonForUse": "Population estimates provide contextual information for regional housing pressure.",
			"geographicLevel": "Territorial Authority / subnational area",
			"url": "https://www.stats.govt.nz/"
		},
		"affordabilityMetric": {
			"metricKey": "affordabilityRatio",
			"sourceName": "Calculated metric; cross-check with HUD Change in Housing Affordability Indicators",
			"sourceType": "derived affordability measure",
			"reasonForUse": "The ratio provides an intuitive comparison of house values against income. HUD indicators provide official context for affordability changes over time.",
			"geographicLevel": "Territorial Authority / regional",
			"url": "https://www.hud.govt.nz/stats-and-insights/change-in-housing-affordability-indicators/indices"
		}
	},
	"methodology": {
		"geographicMatching": {
			"auckland": "Auckland",
			"hamilton": "Hamilton City",
			"christchurch": "Christchurch City",
			"wellington": "Wellington City",
			"queenstown": "Queenstown-Lakes District"
		},
		"calculationNotes": [
			"Affordability ratio is calculated as avgPrice divided by avgIncome.",
			"A higher affordability ratio means stronger affordability pressure.",
			"Queenstown is represented by Queenstown-Lakes District to match official Territorial Authority data.",
			"Use the same source series and geographic level across years to avoid mixing incompatible data."
		],
		"limitations": [
			"Current hard-coded values should be checked against the listed public data sources before final submission.",
			"If any missing yearly values are estimated, the method should be clearly documented in the report and dashboard.",
			"Rent data from bond lodgements reflects new or active bond records and may differ from advertised rents."
		]
	},
